# Raven - Telegram Command Station
# Copy to .env and fill in values

# Telegram
TELEGRAM_BOT_TOKEN=
ALLOWED_USER_IDS= # optional, comma-separated numeric IDs to restrict access

# Backend selection: openai | n8n | relay
DEFAULT_BACKEND=openai

# OpenAI backend
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
SYSTEM_PROMPT=You are Raven, a precise, helpful coding assistant integrated with my development workflow.

# n8n backend (optional)
N8N_WEBHOOK_URL=

# Generic relay backend (optional)
RELAY_URL=

# Runtime
DB_PATH=./data/raven.db
USE_WEBHOOK=false
WEBHOOK_URL= # required if USE_WEBHOOK=true
PORT=8080
