# Τ{Raven} - Telegram Command Station Configuration
# Copy this file to .env and fill in your values

# ============================================
# TELEGRAM CONFIGURATION
# ============================================
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz

# Your Telegram User ID (get from @userinfobot)
# Comma-separated list for multiple users
TELEGRAM_ALLOWED_USERS=123456789,987654321

# Bot username (without @)
TELEGRAM_BOT_USERNAME=YourRavenBot

# ============================================
# AI CONFIGURATION
# ============================================
# Anthropic Claude API Key
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# AI Model to use
AI_MODEL=claude-sonnet-4
# Alternatives: claude-3-5-sonnet-20241022, claude-3-opus-20240229

# Maximum tokens for AI responses
AI_MAX_TOKENS=4096

# Temperature for AI responses (0.0 - 1.0)
AI_TEMPERATURE=0.7

# ============================================
# WORKSPACE CONFIGURATION
# ============================================
# Path to your workspace/repository
WORKSPACE_PATH=/workspace

# Git repository path (usually same as workspace)
GIT_REPO_PATH=/workspace

# Default branch name
GIT_DEFAULT_BRANCH=main

# ============================================
# DATABASE CONFIGURATION (Optional)
# ============================================
# Redis for session management and caching
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# PostgreSQL for conversation history (optional)
POSTGRES_URL=postgresql://raven:password@localhost:5432/raven_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=raven
POSTGRES_PASSWORD=changeme
POSTGRES_DB=raven_db

# ============================================
# SECURITY SETTINGS
# ============================================
# Secret key for session encryption (generate with: openssl rand -hex 32)
SECRET_KEY=your_secret_key_here_generate_a_random_one

# Rate limiting
MAX_REQUESTS_PER_MINUTE=20
MAX_REQUESTS_PER_HOUR=200

# Command timeout (seconds)
COMMAND_TIMEOUT=300

# Maximum file size for operations (MB)
MAX_FILE_SIZE_MB=10

# ============================================
# LOGGING CONFIGURATION
# ============================================
LOG_LEVEL=INFO
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

LOG_FILE=logs/raven.log

# Enable audit logging
AUDIT_LOGGING=true
AUDIT_LOG_FILE=logs/audit.log

# ============================================
# ADVANCED FEATURES (Optional)
# ============================================
# n8n Configuration (if using n8n workflows)
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/raven
N8N_API_KEY=

# Web Interface (if using Telegram Mini App)
WEB_INTERFACE_URL=https://your-domain.com/raven
WEB_INTERFACE_PORT=3000

# RDP Bridge (if using remote desktop option)
RDP_HOST=localhost
RDP_PORT=3389
RDP_USERNAME=
RDP_PASSWORD=

# ============================================
# DEVELOPMENT SETTINGS
# ============================================
# Development mode (enables debug features)
DEVELOPMENT_MODE=false

# Mock responses (for testing without API calls)
MOCK_AI_RESPONSES=false

# Disable rate limiting in development
DISABLE_RATE_LIMITING=false
