{
  "version": "1.0.0",
  "description": "Glyph token semantics for lawline ritual grammar",
  "tokens": {
    "//▞▞": {
      "name": "IMPRINT",
      "description": "Primary banner imprint marker",
      "usage": "File header, ritual initialization",
      "priority": 1
    },
    "▛///▞": {
      "name": "SECTION_HEAD",
      "description": "Anonymous section header",
      "usage": "Begin unnamed structural section",
      "priority": 2
    },
    "▞▞//▟": {
      "name": "SECTION_TAIL",
      "description": "Section terminator",
      "usage": "End structural section",
      "priority": 3
    },
    "▛▞ {name} ▞//": {
      "name": "NAMED_SECTION",
      "description": "Named section with captured identifier",
      "usage": "Begin section with semantic name",
      "pattern": "▛▞\\s+(.+?)\\s+▞//",
      "capture_group": 1,
      "priority": 4
    },
    "▞▞": {
      "name": "COLON2",
      "description": "Double colon semantics marker",
      "usage": "Namespace or semantic binding",
      "priority": 5
    },
    "//▞": {
      "name": "OPEN_MINOR",
      "description": "Minor opening delimiter",
      "usage": "Lightweight section or annotation start",
      "priority": 6
    }
  },
  "rules": {
    "alignment": [
      "Keep banner in comments at file top",
      "Load boot first in every entrypoint",
      "Same tokens across all languages - no drift",
      "Never overload a token with two meanings",
      "Check priority order in classification"
    ],
    "validation": [
      "Banner must appear in first 3 lines",
      "Sections must be properly closed",
      "Named sections must have valid identifiers",
      "No token overlap in same line"
    ]
  }
}
