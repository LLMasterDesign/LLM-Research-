{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llmdesign.ai/schemas/capsule.schema.json",
  "title": "Prompt Capsule",
  "type": "object",
  "required": ["id", "name", "version", "sector", "description", "prompts"],
  "properties": {
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-_]{1,63}$"},
    "name": {"type": "string"},
    "version": {"type": "string"},
    "sector": {"type": "string"},
    "description": {"type": "string"},
    "tags": {"type": "array", "items": {"type": "string"}},
    "created_at": {"type": "string", "format": "date-time"},
    "updated_at": {"type": "string", "format": "date-time"},
    "authors": {"type": "array", "items": {"type": "string"}},
    "license": {"type": "string"},
    "prompts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "role", "content"],
        "properties": {
          "id": {"type": "string"},
          "title": {"type": "string"},
          "role": {"type": "string", "enum": ["system", "user", "assistant", "tool", "template"]},
          "content": {"type": "string"},
          "variables": {"type": "array", "items": {"type": "string"}},
          "input_schema": {"type": "object"},
          "metadata": {"type": "object"}
        },
        "additionalProperties": false
      }
    },
    "lexicon": {"type": ["string", "object"]},
    "files": {"type": "object"}
  },
  "additionalProperties": false
}
