# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather

# Database Configuration
DATABASE_URL=postgresql://glyph:glyphpass@db:5432/glyphforge

# n8n Configuration
N8N_WEBHOOK_URL=http://n8n:5678/webhook/glyph-events

# OpenAI (Optional - for AI compression)
OPENAI_API_KEY=your_openai_api_key_here

# Bot Settings
BOT_DEBUG=false
MAX_GLYPHS_FREE=25
TOKEN_LIMIT=27

# n8n Admin
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=glyphadmin

# Admin Telegram Chat ID (for daily reports)
ADMIN_CHAT_ID=-1001234567890
